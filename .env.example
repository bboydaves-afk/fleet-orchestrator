# Fleet Orchestrator - Environment Variables
# Copy to .env and fill in values
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# JWT signing key (64-char hex)
FLEET_SECRET_KEY=

# Fernet encryption key for credential store
FLEET_ENCRYPTION_KEY=

# Anthropic API key
ANTHROPIC_API_KEY=

# Webhook API key for n8n/external triggers (32-char hex)
AGENTIC_WEBHOOK_API_KEY=

# Agent passwords (Fleet -> Agent authentication)
# Generate each: python -c "import secrets; print(secrets.token_hex(16))"
AGENT_SYSADMIN_AGENT_PASSWORD=
AGENT_AZURE_ARCHITECT_AGENT_PASSWORD=
AGENT_MARKETING_AGENT_PASSWORD=
AGENT_HACKING_AGENT_PASSWORD=
AGENT_NETWORK_AGENT_PASSWORD=
AGENT_COMPLIANCE_AGENT_PASSWORD=
AGENT_VCIO_AGENT_PASSWORD=
AGENT_PSA_AGENT_PASSWORD=
AGENT_ENDPOINT_AGENT_PASSWORD=
AGENT_ONBOARDING_AGENT_PASSWORD=
AGENT_M365_AGENT_PASSWORD=
AGENT_MONITORING_AGENT_PASSWORD=
AGENT_HELPDESK_AGENT_PASSWORD=
AGENT_BACKUP_AGENT_PASSWORD=

# Optional: notification channels
# FLEET_TEAMS_WEBHOOK=
# FLEET_WEBHOOK_URL=
# FLEET_SMTP_HOST=
# FLEET_SMTP_USER=
# FLEET_SMTP_PASS=
# FLEET_EMAIL_FROM=
# FLEET_EMAIL_TO=
